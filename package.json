{
  "name": "ostra-mem",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @ostra-mem/sdk && npm run build -w @ostra-mem/api && npm run build -w @ostra-mem/mcp && npm run build -w @ostra-mem/backend && npm run build -w @ostra-mem/web",
    "build:backend": "npm run build -w @ostra-mem/sdk && npm run build -w @ostra-mem/api && npm run build -w @ostra-mem/mcp && npm run build -w @ostra-mem/backend",
    "test": "npm run test -w @ostra-mem/sdk && npm run test -w @ostra-mem/api",
    "backend:dev": "npm run dev -w @ostra-mem/backend",
    "backend:start": "npm run start -w @ostra-mem/backend",
    "api:dev": "tsx packages/api/src/server.ts",
    "api:smoke": "npm run build && tsx packages/api/examples/smoke.ts",
    "contracts:compile:zama": "node contracts/deploy-zama.mjs --compile-only",
    "contracts:deploy:zama": "node contracts/deploy-zama.mjs",
    "mcp:dev": "tsx packages/mcp/src/server.ts",
    "mcp:http:dev": "tsx packages/mcp/src/http.ts",
    "web:dev": "npm run dev -w @ostra-mem/web",
    "web:build": "npm run build -w @ostra-mem/web",
    "web:preview": "npm run preview -w @ostra-mem/web",
    "example:seed": "tsx packages/sdk/examples/seed-memory.ts",
    "example:vault": "tsx packages/sdk/examples/seed-memory.ts"
  },
  "devDependencies": {
    "@fhevm/solidity": "^0.11.1",
    "@types/node": "^22.13.14",
    "playwright": "^1.61.0",
    "solc": "^0.8.28",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "dependencies": {
    "ethers": "^6.17.0"
  }
}
